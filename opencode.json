{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "lsp": "allow"
  },
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": ["uvx", "lean-lsp-mcp", "--loogle-local"],
      "environment": {
        "LEAN_PROJECT_PATH": "/home/levzlotnik/Projects/SKCQ/some_math",
        "LEAN_LOG_LEVEL": "INFO"
      }
    },
    "arxiv": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-v",
        "/home/levzlotnik/Papers:/papers",
        "arxiv-mcp-server:latest",
        "--storage-path",
        "/papers"
      ],
      "enabled": true
    }
  },
  "skills": {
    "paths": [
      "/home/levzlotnik/Projects/lean4-skills/plugins/lean4/skills/lean4"
    ]
  }
}
